{
  "name": "@qcms/ui",
  "version": "0.0.0",
  "private": false,
  "description": "qcms A2UI renderer: the controlled A2UIStepRenderer over vendored a2-react-aria components (ADR-22)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./native-submit": {
      "types": "./dist/native-submit.d.ts",
      "default": "./dist/native-submit.js"
    },
    "./theme.css": "./src/theme.css"
  },
  "files": [
    "dist",
    "src",
    "a2ra.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. --project @qcms/ui",
    "lint": "eslint src"
  },
  "dependencies": {
    "@a2ra/core": "1.0.0-preview.7",
    "@internationalized/date": "^3.12.2",
    "react-aria-components": "^1.19.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@qcms/core": "workspace:*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "axe-core": "^4.10.2",
    "dom-accessibility-api": "^0.6.3",
    "jsdom": "^26.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
