{
  "name": "@qcms/a2ui-compiler",
  "version": "0.1.0",
  "private": false,
  "description": "qcms FormDefinition-to-A2UI compiler: the pure projection from a published snapshot to A2UI documents (task 011)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. --project @qcms/a2ui-compiler",
    "lint": "eslint src"
  },
  "dependencies": {
    "@qcms/core": "workspace:*"
  },
  "devDependencies": {
    "@a2ra/core": "1.0.0-preview.7",
    "@types/node": "^24.13.3"
  }
}
