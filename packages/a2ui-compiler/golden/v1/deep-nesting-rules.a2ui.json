{
  "documents": [
    {
      "stepId": "stp_source",
      "root": {
        "type": "Form",
        "children": [
          {
            "type": "Flex",
            "props": {
              "direction": "column",
              "gap": "md"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "as": "h1"
                },
                "children": "Deep nesting rules"
              },
              {
                "type": "Text",
                "props": {
                  "as": "h2"
                },
                "children": "Source answers"
              },
              {
                "type": "TextField",
                "props": {
                  "label": "Full name",
                  "description": "As shown on your photo ID",
                  "name": "q_full_name",
                  "isRequired": true,
                  "minLength": 1,
                  "maxLength": 100,
                  "pattern": "^[A-Za-z][A-Za-z .,'-]{0,99}$"
                }
              },
              {
                "type": "NumberField",
                "props": {
                  "label": "How many?",
                  "description": "An average across the last 12 months",
                  "name": "q_accident_count",
                  "isRequired": true,
                  "minValue": 0,
                  "maxValue": 200,
                  "step": 1
                }
              },
              {
                "type": "DatePicker",
                "props": {
                  "label": "Date of birth",
                  "name": "q_dob",
                  "isRequired": true,
                  "granularity": "day",
                  "minValue": "1900-01-01",
                  "maxValue": "2100-12-31"
                }
              },
              {
                "type": "RadioGroup",
                "props": {
                  "label": "Any at-fault accident in the last 3 years?",
                  "name": "q_at_fault_accident",
                  "isRequired": true
                },
                "children": [
                  {
                    "type": "Radio",
                    "props": {
                      "value": "true",
                      "label": "Yes"
                    }
                  },
                  {
                    "type": "Radio",
                    "props": {
                      "value": "false",
                      "label": "No"
                    }
                  }
                ]
              },
              {
                "type": "RadioGroup",
                "props": {
                  "label": "Which coverage level would you like?",
                  "name": "q_coverage_level",
                  "isRequired": true
                },
                "children": [
                  {
                    "type": "Radio",
                    "props": {
                      "value": "opt_basic",
                      "label": "Basic"
                    }
                  },
                  {
                    "type": "Radio",
                    "props": {
                      "value": "opt_standard",
                      "label": "Standard"
                    }
                  },
                  {
                    "type": "Radio",
                    "props": {
                      "value": "opt_premium",
                      "label": "Premium"
                    }
                  },
                  {
                    "type": "Radio",
                    "props": {
                      "value": "opt_none",
                      "label": "No cover for now"
                    }
                  }
                ]
              },
              {
                "type": "CheckboxGroup",
                "props": {
                  "label": "Do any of these conditions apply to you?",
                  "description": "Select all that apply",
                  "name": "q_preexisting_conditions",
                  "isRequired": true,
                  "orientation": "vertical"
                },
                "children": [
                  {
                    "type": "Checkbox",
                    "props": {
                      "value": "opt_diabetes",
                      "label": "Diabetes"
                    }
                  },
                  {
                    "type": "Checkbox",
                    "props": {
                      "value": "opt_asthma",
                      "label": "Asthma"
                    }
                  },
                  {
                    "type": "Checkbox",
                    "props": {
                      "value": "opt_heart_disease",
                      "label": "Heart disease"
                    }
                  },
                  {
                    "type": "Checkbox",
                    "props": {
                      "value": "opt_none",
                      "label": "None of the above"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "stepId": "stp_target",
      "root": {
        "type": "Form",
        "children": [
          {
            "type": "Flex",
            "props": {
              "direction": "column",
              "gap": "md"
            },
            "children": [
              {
                "type": "Text",
                "props": {
                  "as": "h2"
                },
                "children": "Conditional detail"
              },
              {
                "type": "TextArea",
                "props": {
                  "label": "Relevant medical history",
                  "name": "q_medical_history",
                  "maxLength": 2000
                }
              }
            ]
          }
        ]
      }
    }
  ],
  "compilerVersion": "0.0.0",
  "a2uiSpecVersion": "1.0.0-preview.7"
}
