{
  "formId": "frm_g_ops_contains",
  "defaultLocale": "en",
  "title": {
    "en": "frm_g_ops_contains"
  },
  "steps": [
    {
      "stepId": "stp_src",
      "title": {
        "en": "stp_src"
      },
      "items": [
        {
          "questionId": "q_preexisting_conditions",
          "version": 1
        }
      ]
    },
    {
      "stepId": "stp_gates",
      "title": {
        "en": "stp_gates"
      },
      "items": [
        {
          "questionId": "q_gate_a",
          "version": 1
        },
        {
          "questionId": "q_gate_b",
          "version": 1
        },
        {
          "questionId": "q_gate_c",
          "version": 1
        }
      ]
    }
  ],
  "rules": [
    {
      "ruleId": "rul_contains",
      "when": {
        "op": "contains",
        "questionId": "q_preexisting_conditions",
        "value": "opt_asthma"
      },
      "show": ["q_gate_a"]
    },
    {
      "ruleId": "rul_contains_any",
      "when": {
        "op": "containsAny",
        "questionId": "q_preexisting_conditions",
        "values": ["opt_diabetes", "opt_heart_disease"]
      },
      "show": ["q_gate_b"]
    },
    {
      "ruleId": "rul_equals_exact",
      "when": {
        "op": "equals",
        "questionId": "q_preexisting_conditions",
        "value": ["opt_asthma"]
      },
      "show": ["q_gate_c"]
    }
  ]
}
