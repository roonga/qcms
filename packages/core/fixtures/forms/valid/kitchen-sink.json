{
  "formId": "frm_kitchen_sink",
  "defaultLocale": "en",
  "title": { "en": "Kitchen sink" },
  "steps": [
    {
      "stepId": "stp_about",
      "title": { "en": "About you" },
      "items": [
        { "questionId": "q_full_name", "version": 1 },
        { "questionId": "q_dob", "version": 1 }
      ]
    },
    {
      "stepId": "stp_history",
      "title": { "en": "Driving history" },
      "items": [
        { "questionId": "q_at_fault_accident", "version": 2 },
        { "questionId": "q_accident_count", "version": 1 },
        { "questionId": "q_preexisting_conditions", "version": 1 },
        { "questionId": "q_medical_history", "version": 1 }
      ]
    },
    {
      "stepId": "stp_cover",
      "title": { "en": "Your cover" },
      "items": [{ "questionId": "q_coverage_level", "version": 1 }]
    }
  ],
  "rules": [
    {
      "ruleId": "rul_accident_followup",
      "when": { "op": "equals", "questionId": "q_at_fault_accident", "value": true },
      "show": ["q_accident_count"]
    },
    {
      "ruleId": "rul_condition_details",
      "when": {
        "op": "containsAny",
        "questionId": "q_preexisting_conditions",
        "values": ["opt_diabetes", "opt_asthma", "opt_heart_disease"]
      },
      "show": ["q_medical_history"]
    }
  ]
}
