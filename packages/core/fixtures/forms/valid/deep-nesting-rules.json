{
  "formId": "frm_deep_nesting_rules",
  "defaultLocale": "en",
  "title": { "en": "Deep nesting rules" },
  "steps": [
    {
      "stepId": "stp_source",
      "title": { "en": "Source answers" },
      "items": [
        { "questionId": "q_full_name", "version": 1 },
        { "questionId": "q_accident_count", "version": 1 },
        { "questionId": "q_dob", "version": 1 },
        { "questionId": "q_at_fault_accident", "version": 2 },
        { "questionId": "q_coverage_level", "version": 1 },
        { "questionId": "q_preexisting_conditions", "version": 1 }
      ]
    },
    {
      "stepId": "stp_target",
      "title": { "en": "Conditional detail" },
      "items": [{ "questionId": "q_medical_history", "version": 1 }]
    }
  ],
  "rules": [
    {
      "ruleId": "rul_depth_8",
      "when": {
        "op": "and",
        "conditions": [
          {
            "op": "or",
            "conditions": [
              {
                "op": "and",
                "conditions": [
                  {
                    "op": "or",
                    "conditions": [
                      {
                        "op": "and",
                        "conditions": [
                          {
                            "op": "or",
                            "conditions": [
                              {
                                "op": "and",
                                "conditions": [
                                  {
                                    "op": "equals",
                                    "questionId": "q_at_fault_accident",
                                    "value": true
                                  },
                                  { "op": "gt", "questionId": "q_accident_count", "value": 0 }
                                ]
                              },
                              {
                                "op": "equals",
                                "questionId": "q_coverage_level",
                                "value": "opt_none"
                              }
                            ]
                          },
                          { "op": "answered", "questionId": "q_dob" }
                        ]
                      },
                      {
                        "op": "contains",
                        "questionId": "q_preexisting_conditions",
                        "value": "opt_none"
                      }
                    ]
                  },
                  { "op": "notEquals", "questionId": "q_full_name", "value": "Nobody" }
                ]
              },
              { "op": "in", "questionId": "q_accident_count", "values": [999] }
            ]
          },
          { "op": "lte", "questionId": "q_accident_count", "value": 200 }
        ]
      },
      "show": ["q_medical_history"]
    }
  ]
}
