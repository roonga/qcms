{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(pnpm:*)",
      "Bash(git:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(docker:*)",
      "PowerShell(pnpm:*)",
      "PowerShell(git:*)",
      "PowerShell(node:*)",
      "PowerShell(npx:*)",
      "PowerShell(docker:*)"
    ],
    "deny": [
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "PowerShell(npm:*)",
      "PowerShell(yarn:*)",
      "Bash(git push --force:*)",
      "PowerShell(git push --force:*)"
    ]
  }
}
