{
  "name": "qcms",
  "version": "0.0.0",
  "private": true,
  "description": "Question CMS - TypeScript engine for questionnaires with deeply conditional logic",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:golden-drift": "vitest run --project @qcms/core packages/core/src/golden-corpus.test.ts",
    "check:golden-append-only": "node scripts/check-golden-append-only.mjs",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint && prettier --check .",
    "format": "prettier --write .",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
