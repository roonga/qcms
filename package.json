{
  "name": "qcms",
  "version": "0.0.0",
  "private": true,
  "description": "QCMS: a TypeScript engine for questionnaires with deeply conditional logic",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "dev:portal": "node scripts/dev-portal.mjs",
    "test": "turbo run test",
    "test:golden-drift": "vitest run --project @qcms/core packages/core/src/golden-corpus.test.ts",
    "check:golden-append-only": "node scripts/check-golden-append-only.mjs",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint && prettier --check .",
    "format": "prettier --write .",
    "changeset": "changeset",
    "check:no-control-chars": "node scripts/check-no-control-chars.mjs",
    "openapi:generate": "pnpm --filter qcms-api build && node apps/api/scripts/generate-openapi.mjs",
    "openapi:check": "vitest run --project qcms-api openapi-document.test.ts",
    "check:licenses": "node scripts/check-licenses.mjs",
    "check:no-em-dash": "node scripts/check-no-em-dash.mjs",
    "check:duplication": "jscpd packages apps --config .jscpd.json --threshold 3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "4.1.10",
    "chrome-launcher": "^1.2.1",
    "eslint": "^10.7.0",
    "eslint-plugin-sonarjs": "^4.2.0",
    "jscpd": "^5.0.12",
    "lighthouse": "^13.4.1",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "ignoredOptionalDependencies": [
      "sharp"
    ]
  }
}
