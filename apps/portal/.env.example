# QCMS portal - server-only configuration (task 029).
# The portal is a strict BFF: these values stay on the server and never reach the
# client bundle. Copy to .env.local for local development.

# The internal API base URL (server-only). The API container is never published
# (ADR-20); only the portal's BFF reaches it. No trailing slash needed.
QCMS_API_BASE_URL=http://127.0.0.1:3000

# The SEC-4 internal service token presented on every API call (>= 32 chars).
# Must match one of the API's QCMS_INTERNAL_TOKEN values.
QCMS_INTERNAL_TOKEN=replace-with-a-32-char-plus-internal-token

# Pre-session challenge provider (ADR-24, SEC-9). Default (unset) = none: no
# challenge code loads and the CSP names no challenge origin. Set to `turnstile`
# to render the Cloudflare Turnstile widget on entry pages.
# QCMS_FLAG_CHALLENGE_PROVIDER=turnstile

# The public Turnstile site key (only used when the flag above is `turnstile`).
# QCMS_TURNSTILE_SITE_KEY=
